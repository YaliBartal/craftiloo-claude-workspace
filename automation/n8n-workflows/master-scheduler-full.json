        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"channel\": \"#claude-alerts\",\n  \"text\": \":warning: *Skill Failed* — {{ $('Run: ' + $input.first().json.skill || 'unknown').params.command }}\\nExit code: {{ $json.exitCode }}\\nTime: {{ $now.toISO() }}\\nCheck n8n executions or server logs for details.\"\n}"
