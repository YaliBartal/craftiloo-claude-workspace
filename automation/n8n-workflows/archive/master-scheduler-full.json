        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"channel\": \"#claude-alerts\",\n  \"text\": \":red_circle: *Skill failed* — check n8n executions for details.\\nTime: {{ $now.toISO() }}\"\n}"
